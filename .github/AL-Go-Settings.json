{
  "$schema": "https://raw.githubusercontent.com/freddydk/AL-Go/main/Actions/.Modules/settings.schema.json",
  "type": "PTE",
  "templateUrl": "https://github.com/freddydk/AL-Go@main",
  "useProjectDependencies": true,
  "useCompilerFolder": true,
  "doNotPublishApps": true,
  "runs-on": "ubuntu-latest",
  "githubRunner": "ubuntu-latest",
  "country": "w1",
  "artifact": "/sandbox/28.1.49838.50480/w1",
  "doNotSignApps": true,
  "generateDependencyArtifact": true,
  "incrementalBuilds": {
    "onPush": true,
    "onPull_Request": true,
    "onSchedule": false,
    "mode": "modifiedApps",
    "retentionDays": 30
  },
  "fkh": {
    "CreateContainer.cpu": "250m",
    "CreateContainer.memory": "3Gi",
    "CreateContainer.spot": "false",
    "CreateContainer.moveAllAppsToDevScope": "true",
    "CreateContainer.multitenant": "false",
    "CreateContainer.updateLaunchJson": "repo",
    "CreateContainer.useDatabase": "",
    "CreateContainer.tenantDatabase": "",
    "CreateContainer.licenseFileUrl": "",
    "CreateContainer.authenticationEmail": "",
    "CreateContainer.startupObjectId": 130451,
    "CreateContainer.autostop?": "18:00",
    "StartContainer.autostop?": "18:00"
  },
  "deliverToStorage": {
    "CreateContainerIfNotExist": true
  },
  "templateSha": "ec5e18214e098ee0a53a996426174f7dfae6d0db",
  "conditionalSettings": [
    {
      "projects": [
        "*DK"
      ],
      "settings": {
        "country": "dk",
        "artifact": "/sandbox/28.1.49838.50480/dk"
      }
    },
    {
      "projects": [
        "*DE"
      ],
      "settings": {
        "country": "de",
        "artifact": "/sandbox/28.1.49838.50480/de"
      }
    },
    {
      "projects": [
        "Test *"
      ],
      "settings": {
        "postponeProjectInBuildOrder": true,
        "doNotPublishApps": false,
        "fkh": {
          "ignoreProject": true
        }
      }
    }
  ]
}
